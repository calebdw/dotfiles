{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": "notify",
    "lsp": {
        "php intelephense": { "disabled": true },
        "phpantom_lsp": {
            "command": ["phpantom_lsp"],
            "extensions": [".php"]
        }
    },
    "mcp": {
        "voice-mode": {
            "type": "local",
            "command": ["uvx", "--refresh", "voice-mode"],
            "enabled": true,
            "environment": {
                "xVOICEMODE_PREFER_LOCAL": "true",
                "xVOICEMODE_ALWAYS_TRY_LOCAL": "true",
                "VOICEMODE_DEBUG": "false",
                "VOICEMODE_SAVE_AUDIO": "false",
                "VOICEMODE_TTS_SPEED": "1.5"
            }
        }
    },
    "experimental": {
        // 5 minutes, prevent voice mode from timing out
        "mcp_timeout": 6000000
    },
    "model": "anthropic/claude-opus-4-7",
    "plugin": ["opencode-with-claude@latest"],
    "provider": {
      "anthropic": {
        "options": {
          "baseURL": "http://127.0.0.1:3456",
          "apiKey": "x"
        }
      }
    }
}
